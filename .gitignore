.zsh_history
tmux/.config/tmux/plugins/
**/.zcompdump
yazi/.config/yazi/package.toml
cura/.local/share/cura/.sentry-native/
cura/.local/share/cura/stderr.log
cura/.local/share/cura/stdout.log
zsh/.config/zsh/secrets.env

# pi runtime data — secrets, sessions, and migration artifacts.
# The directory itself is stowed; these specific files must never be tracked.
pi/.config/pi/agent/auth.json
pi/.config/pi/agent/auth.json.migrated
pi/.config/pi/agent/oauth.json
pi/.config/pi/agent/oauth.json.migrated
pi/.config/pi/agent/sessions/
pi/.config/pi/agent/*.jsonl

# Defense-in-depth: yazi's omarchy-theme.toml is a runtime symlink at
# ~/.config/yazi/, never inside the package. If it ever shows up here it
# means stow folded the directory and the symlink landed in-tree — which
# bootstrap's NO_FOLD_PACKAGES is supposed to prevent.
yazi/.config/yazi/omarchy-theme.toml
