#!/bin/bash
# Omarchy theme-set hook for zfiles.
#
# Most theme outputs (yazi, mako) live as Omarchy user templates under
# omarchy/.config/omarchy/themed/*.tpl and are rendered by Omarchy's own
# template engine — no logic here required for them.
#
# This hook handles the two cases that don't fit Omarchy's templating:
#   - sioyek: needs RGB as space-separated floats (0.0–1.0), but the
#     template engine only emits hex / decimal-RGB.
#   - opencode: needs an Omarchy-theme → opencode-theme name mapping.
#
# Output files are written to ~/.config/omarchy/current/theme/, the same
# place Omarchy's templates render to. Consuming configs symlink into that
# dir (see bootstrap.sh).
#
# Called with: $1 = theme name (e.g., "catppuccin")

set -e

THEME_NAME="$1"
THEME_DIR="$HOME/.config/omarchy/current/theme"
COLORS_FILE="$THEME_DIR/colors.toml"

if [[ ! -f "$COLORS_FILE" ]]; then
    echo "theme-set hook: No colors.toml at $COLORS_FILE, skipping"
    exit 0
fi

# Read a hex color value from colors.toml. Tolerates `key = "#xxx"` and
# `key="#xxx"`. (colors.toml uses full-line comments only, so no inline
# comment stripping — and stripping `#.*$` would eat the color hex.)
get_color() {
    awk -F'=' -v k="$1" '
        $1 ~ ("^[[:space:]]*"k"[[:space:]]*$") {
            v = $2
            gsub(/[[:space:]"\047]/, "", v)  # strip whitespace and quotes
            print v
            exit
        }
    ' "$COLORS_FILE"
}

# === Sioyek: RGB-float prefs ===
# Sioyek wants colors as "R G B" with each in [0.0, 1.0]. Render the full
# prefs file (no static base needed; sioyek prefs are entirely theme colors
# in our setup). Atomic write via tmp+mv.
hex_to_rgb_float() {
    local hex="${1#\#}"
    awk -v h="$hex" 'BEGIN {
        r = strtonum("0x" substr(h,1,2))
        g = strtonum("0x" substr(h,3,2))
        b = strtonum("0x" substr(h,5,2))
        printf "%.3f %.3f %.3f", r/255, g/255, b/255
    }'
}

bg_rgb=$(hex_to_rgb_float "$(get_color background)")
fg_rgb=$(hex_to_rgb_float "$(get_color foreground)")
sel_rgb=$(hex_to_rgb_float "$(get_color selection_background)")
accent_rgb=$(hex_to_rgb_float "$(get_color color4)")
warn_rgb=$(hex_to_rgb_float "$(get_color color3)")

SIOYEK_OUT="$THEME_DIR/sioyek-prefs.config"
cat > "$SIOYEK_OUT.tmp" << EOF
# Auto-generated by zfiles theme-set hook — theme: $THEME_NAME
# Consumed via symlink: ~/.config/sioyek/prefs_user.config
background_color $bg_rgb
custom_background_color $bg_rgb
custom_text_color $fg_rgb
text_highlight_color $warn_rgb
synctex_highlight_color $accent_rgb
link_highlight_color $accent_rgb
search_highlight_color $sel_rgb
EOF
mv "$SIOYEK_OUT.tmp" "$SIOYEK_OUT"
echo "theme-set hook: Wrote $SIOYEK_OUT"

# Hot-swap: push new colors to any running sioyek. reload_config picks up
# highlight/link colors and the chrome bg; set_custom_*_color is required
# to re-render the PDF page itself when in custom color mode (the page
# render caches don't refresh on reload_config alone). pgrep guard prevents
# --execute-command from spawning a blank window when no sioyek is running.
if pgrep -x sioyek >/dev/null; then
    sioyek --execute-command reload_config 2>/dev/null || true
    sioyek --execute-command set_custom_background_color \
           --execute-command-data "$bg_rgb" 2>/dev/null || true
    sioyek --execute-command set_custom_text_color \
           --execute-command-data "$fg_rgb" 2>/dev/null || true
    echo "theme-set hook: Pushed colors to running sioyek"
fi

# === Opencode TUI theme name mapping ===
# Map Omarchy theme name → opencode's built-in TUI theme name. Templates
# can't express conditional name mapping, so this stays in code.
case "$THEME_NAME" in
    catppuccin|catppuccin-latte) OC_THEME="catppuccin" ;;
    everforest)                  OC_THEME="everforest" ;;
    flexoki-light)               OC_THEME="flexoki" ;;
    gruvbox)                     OC_THEME="gruvbox" ;;
    kanagawa)                    OC_THEME="kanagawa" ;;
    nord)                        OC_THEME="nord" ;;
    osaka-jade)                  OC_THEME="osaka-jade" ;;
    rose-pine)                   OC_THEME="rosepine" ;;
    tokyo-night)                 OC_THEME="tokyonight" ;;
    matte-black|vantablack)      OC_THEME="amoled" ;;
    hackerman)                   OC_THEME="matrix" ;;
    white)                       OC_THEME="github" ;;
    *)                           OC_THEME="opencode" ;;
esac

OPENCODE_TUI="$HOME/.config/opencode/tui.json"
mkdir -p "$(dirname "$OPENCODE_TUI")"
cat > "$OPENCODE_TUI.tmp" << EOF
{
  "\$schema": "https://opencode.ai/tui.json",
  "theme": "$OC_THEME"
}
EOF
mv "$OPENCODE_TUI.tmp" "$OPENCODE_TUI"
echo "theme-set hook: Set opencode TUI theme to $OC_THEME"

# Re-signal opencode so it picks up the new tui.json. omarchy-restart-opencode
# already restarted it once before our hook ran, but with the OLD tui.json.
if pgrep -x opencode >/dev/null; then
    killall -SIGUSR2 opencode 2>/dev/null || true
fi
