# Sioyek user keybindings — zathura-style overlay.
# Loaded after /etc/sioyek/keys.config; entries here override defaults.
# Sioyek does NOT hot-reload — restart sioyek after editing.

# --- Zoom (zathura-style) ---
# Default sioyek: + zooms in, - zooms out. We add J/K too.
zoom_in K
zoom_out J

# --- Page navigation (zathura-style h/l = prev/next page) ---
# Overrides defaults: h was add_highlight, l was overview_definition.
# Use SHIFT+H / SHIFT+L (or the toolbar) for those if you need them.
previous_page h
next_page l

# --- Scroll (zathura-style j/k = scroll down/up by screen) ---
# Overrides defaults: j/k were move_visual_mark_down/up.
# Visual marks still work via arrow keys.
screen_down j
screen_up k

# --- Fit modes (zathura-style) ---
# Default sioyek: = is fit_to_page_width. Add zathura's a (best-fit) and s (width).
fit_to_page_width_smart a
fit_to_page_width s

# --- Invert / dark mode (zathura's i / Ctrl+R equivalent) ---
toggle_dark_mode i
