# Non-color sioyek prefs. Theme colors are appended below by the
# theme-set hook between '# zfiles-theme' markers — do not edit that block.

# Visual
fit_to_page_width_ratio 0.95
should_use_multiple_monitors 0
should_draw_unrendered_pages 1

# Behavior
single_main_window 1
ruler_mode 0

# vimtex inverse search → expects nvim launched with --listen /tmp/nvimsocket
# (see :h vimtex-synctex-inverse-search). Inverse from sioyek with Ctrl+Click.
inverse_search_command nvim --server /tmp/nvimsocket --remote-send "%2G"
